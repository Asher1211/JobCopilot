# LLM — configured per-user via Settings page
# Each user brings their own API key, base URL, and model.
# Supported: any OpenAI-compatible API (DeepSeek, OpenAI, Groq, Ollama, etc.)

# Embedding — local, no API key needed (BAAI/bge-small-zh-v1.5)

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=interview_questions

# Relational DB
DATABASE_URL=postgresql+asyncpg://jobcopilot:jobcopilot@localhost:5432/jobcopilot

# Monitoring (optional)
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=job-copilot

# Auth
JWT_SECRET=change-me

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
DAILY_CALL_LIMIT=20
REDIS_URL=redis://localhost:6379
